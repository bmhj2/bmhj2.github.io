# Auto detect text files and normalise line endings to LF
* text=auto

# Git files
.gitattributes text eol=lf
.gitignore text eol=lf

# Quarto-specific
*.qmd text eol=lf
*.ipynb text eol=lf
_quarto.yml text eol=lf
_metadata.yml text eol=lf
_extensions/ text eol=lf
_freeze/ text eol=lf

# R and Python
*.R text eol=lf
*.py text eol=lf
*.r text eol=lf
*.Rmd text eol=lf

# Source code and markup
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.sass text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.bash text eol=lf

# Configuration and documentation
.Rprofile text eol=lf
.Rbuildignore text eol=lf
requirements.txt text eol=lf
environment.yml text eol=lf
environment.yaml text eol=lf
setup.py text eol=lf
pyproject.toml text eol=lf

# Binary files and outputs (don't normalise these)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.ico binary
*.pdf binary
*.docx binary
*.xlsx binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary